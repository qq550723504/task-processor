{
  "info": {
    "name": "Task Processor API Collection",
    "description": "API collection for testing Task Processor endpoints, including task status flow and RabbitMQ message handling",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "auth": {
    "type": "oauth2",
    "oauth2": [
      {
        "key": "accessToken",
        "value": "{{access_token}}",
        "type": "string"
      },
      {
        "key": "tokenType",
        "value": "Bearer",
        "type": "string"
      },
      {
        "key": "addTokenTo",
        "value": "header",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://getway.linkcloudai.com",
      "type": "string"
    },
    {
      "key": "client_id",
      "value": "go-listing",
      "type": "string"
    },
    {
      "key": "client_secret",
      "value": "go-listing-secret",
      "type": "string"
    },
    {
      "key": "token_url",
      "value": "http://getway.linkcloudai.com/admin-api/system/oauth2/token",
      "type": "string"
    },
    {
      "key": "tenant_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "user_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "store_id",
      "value": "169",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "task_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Get Access Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 解析响应",
                  "var jsonData = pm.response.json();",
                  "",
                  "// 保存 access_token 到环境变量",
                  "if (jsonData.access_token) {",
                  "    pm.collectionVariables.set('access_token', jsonData.access_token);",
                  "    console.log('Access token saved:', jsonData.access_token);",
                  "} else {",
                  "    console.error('No access_token in response');",
                  "}",
                  "",
                  "// 验证响应状态",
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has access_token', function () {",
                  "    pm.expect(jsonData.access_token).to.exist;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "grant_type",
                  "value": "client_credentials",
                  "type": "text"
                },
                {
                  "key": "client_id",
                  "value": "{{client_id}}",
                  "type": "text"
                },
                {
                  "key": "client_secret",
                  "value": "{{client_secret}}",
                  "type": "text"
                },
                {
                  "key": "scope",
                  "value": "user.read",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{token_url}}",
              "host": ["{{token_url}}"]
            },
            "description": "获取 OAuth2 访问令牌用于后续 API 调用"
          },
          "response": []
        }
      ],
      "description": "认证相关的 API 端点"
    },
    {
      "name": "Import Tasks",
      "item": [
        {
          "name": "Get Pending and Retry Tasks",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "",
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has data array', function () {",
                  "    pm.expect(jsonData.data).to.be.an('array');",
                  "});",
                  "",
                  "// 如果有任务，保存第一个任务的ID",
                  "if (jsonData.data && jsonData.data.length > 0) {",
                  "    pm.collectionVariables.set('task_id', jsonData.data[0].id);",
                  "    console.log('Saved task_id:', jsonData.data[0].id);",
                  "    console.log('Task status:', jsonData.data[0].status);",
                  "    console.log('Task platform:', jsonData.data[0].platform);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              },
              {
                "key": "tenant-id",
                "value": "{{tenant_id}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/rpc-api/listing/import-task/list-pending-and-retry?limit=10&userId={{user_id}}&storeIds={{store_id}}",
              "host": ["{{base_url}}"],
              "path": ["rpc-api", "listing", "import-task", "list-pending-and-retry"],
              "query": [
                {
                  "key": "limit",
                  "value": "10",
                  "description": "最大返回任务数量"
                },
                {
                  "key": "userId",
                  "value": "{{user_id}}",
                  "description": "用户ID（可选）"
                },
                {
                  "key": "storeIds",
                  "value": "{{store_id}}",
                  "description": "店铺ID列表"
                }
              ]
            },
            "description": "获取待处理和待重试的任务列表\n\n**响应字段说明：**\n- `status`: int16 类型 (0=待处理, 1=处理中, 2=已抓取, 3=抓取失败, 4=待重试, 5=队列中, 6=已上架, 8=草稿箱, 10=已暂停, 13=已终止)"
          },
          "response": []
        },
        {
          "name": "Update Task Status",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "",
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response code is 0 (success)', function () {",
                  "    pm.expect(jsonData.code).to.equal(0);",
                  "});",
                  "",
                  "console.log('Task status updated successfully');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              },
              {
                "key": "tenant-id",
                "value": "{{tenant_id}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": {{task_id}},\n  \"status\": 1,\n  \"errorMessage\": \"\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/rpc-api/listing/import-task/update-status",
              "host": ["{{base_url}}"],
              "path": ["rpc-api", "listing", "import-task", "update-status"]
            },
            "description": "更新任务状态\n\n**状态码说明：**\n- 0: 待处理 (TaskStatusPending)\n- 1: 处理中 (TaskStatusProcessing)\n- 2: 已抓取 (TaskStatusCrawled)\n- 3: 抓取失败 (TaskStatusCrawlFailed)\n- 4: 待重试 (TaskStatusPendingRetry)\n- 5: 队列中 (TaskStatusQueued)\n- 6: 已上架 (TaskStatusPublished)\n- 8: 草稿箱 (TaskStatusDraft)\n- 10: 已暂停 (TaskStatusPaused)\n- 13: 已终止 (TaskStatusTerminated)"
          },
          "response": []
        }
      ],
      "description": "导入任务相关的 API 端点"
    },
    {
      "name": "RabbitMQ Message Simulation",
      "item": [
        {
          "name": "Simulate Task Message (Pending)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"taskId\": 12345,\n  \"tenantId\": 1,\n  \"storeId\": 169,\n  \"platform\": \"amazon\",\n  \"targetPlatform\": \"temu\",\n  \"region\": \"us\",\n  \"categoryId\": 100,\n  \"productId\": \"B08N5WRWNW\",\n  \"priority\": 5,\n  \"retryCount\": 0,\n  \"maxRetryCount\": 3,\n  \"createdAt\": 1678886400000,\n  \"status\": \"pending\",\n  \"remark\": \"\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://localhost:15672/api/exchanges/%2F/task.exchange/publish",
              "protocol": "http",
              "host": ["localhost"],
              "port": "15672",
              "path": ["api", "exchanges", "%2F", "task.exchange", "publish"]
            },
            "description": "模拟发送一个 pending 状态的任务消息到 RabbitMQ\n\n**注意：** 这个请求需要 RabbitMQ Management API 的访问权限\n\n**字段说明：**\n- platform: 爬虫平台（数据来源，如 \"amazon\"）\n- targetPlatform: 目标上架平台（如 \"temu\", \"shein\", \"amazon\"）\n- status: Java 后端使用字符串类型（\"pending\", \"processing\", \"completed\", \"failed\"），Go 前端会将其转换为 int16 类型"
          },
          "response": []
        },
        {
          "name": "Simulate Task Message (Processing)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"taskId\": 12346,\n  \"tenantId\": 1,\n  \"storeId\": 169,\n  \"platform\": \"1688\",\n  \"targetPlatform\": \"temu\",\n  \"region\": \"us\",\n  \"categoryId\": 200,\n  \"productId\": \"PROD-001\",\n  \"priority\": 7,\n  \"retryCount\": 0,\n  \"maxRetryCount\": 3,\n  \"createdAt\": 1678886400000,\n  \"status\": \"processing\",\n  \"remark\": \"\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://localhost:15672/api/exchanges/%2F/task.exchange/publish",
              "protocol": "http",
              "host": ["localhost"],
              "port": "15672",
              "path": ["api", "exchanges", "%2F", "task.exchange", "publish"]
            },
            "description": "模拟发送一个 processing 状态的任务消息到 RabbitMQ\n\n**字段说明：**\n- platform: 爬虫平台（数据来源，如 \"1688\"）\n- targetPlatform: 目标上架平台（如 \"temu\"）"
          },
          "response": []
        },
        {
          "name": "Simulate Task Message (Failed)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"taskId\": 12347,\n  \"tenantId\": 1,\n  \"storeId\": 169,\n  \"platform\": \"amazon\",\n  \"targetPlatform\": \"shein\",\n  \"region\": \"global\",\n  \"categoryId\": 300,\n  \"productId\": \"PROD-002\",\n  \"priority\": 3,\n  \"retryCount\": 2,\n  \"maxRetryCount\": 3,\n  \"createdAt\": 1678886400000,\n  \"status\": \"failed\",\n  \"remark\": \"Test failure\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://localhost:15672/api/exchanges/%2F/task.exchange/publish",
              "protocol": "http",
              "host": ["localhost"],
              "port": "15672",
              "path": ["api", "exchanges", "%2F", "task.exchange", "publish"]
            },
            "description": "模拟发送一个 failed 状态的任务消息到 RabbitMQ\n\n**字段说明：**\n- platform: 爬虫平台（数据来源，如 \"amazon\"）\n- targetPlatform: 目标上架平台（如 \"shein\"）"
          },
          "response": []
        }
      ],
      "description": "模拟 RabbitMQ 消息发送（用于测试消息处理流程）"
    },
    {
      "name": "Health Checks",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8081/health",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8081",
              "path": ["health"]
            },
            "description": "检查服务健康状态"
          },
          "response": []
        },
        {
          "name": "Ready Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8081/ready",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8081",
              "path": ["ready"]
            },
            "description": "检查服务就绪状态"
          },
          "response": []
        },
        {
          "name": "Metrics",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8082/metrics",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8082",
              "path": ["metrics"]
            },
            "description": "获取服务指标"
          },
          "response": []
        },
        {
          "name": "Stats",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8082/stats",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8082",
              "path": ["stats"]
            },
            "description": "获取服务统计信息"
          },
          "response": []
        }
      ],
      "description": "健康检查和监控端点"
    }
  ]
}
