# syntax=docker/dockerfile:1

# Deprecated:
# ListingKit product-listing-api no longer uses this runtime base by default.
# The default runtime is now xuwei190/crawler-env:latest via
# deployments/docker/Dockerfile.product-listing-api and
# .github/workflows/listingkit-deploy.yml.
#
# This image preinstalls Playwright and fingerprint browser assets, which makes
# the final image several gigabytes larger. Keep this file only for manual
# experiments that explicitly need preinstalled browser binaries.

FROM golang:1.25-alpine AS installer-builder

WORKDIR /src

RUN apk add --no-cache git

COPY go.mod go.sum ./
RUN go mod download

COPY cmd/playwright-installer ./cmd/playwright-installer
COPY cmd/fingerprint-browser-installer ./cmd/fingerprint-browser-installer
COPY internal ./internal

RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /out/playwright-installer ./cmd/playwright-installer/main.go
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /out/fingerprint-browser-installer ./cmd/fingerprint-browser-installer/main.go

FROM mcr.microsoft.com/playwright:v1.55.0-noble

WORKDIR /app

ENV TZ=Asia/Shanghai
ENV FINGERPRINT_CHROME_VERSION=144
ENV FINGERPRINT_CHROME_DIR=/opt/fingerprint-chrome
ENV FINGERPRINT_CHROME_DOWNLOAD_TIMEOUT=30m

COPY --from=installer-builder /out/playwright-installer /usr/local/bin/playwright-installer
COPY --from=installer-builder /out/fingerprint-browser-installer /usr/local/bin/fingerprint-browser-installer

RUN apt-get -o Acquire::Retries=5 -o Acquire::http::Timeout=30 -o Acquire::https::Timeout=30 update && \
    DEBIAN_FRONTEND=noninteractive apt-get -o Acquire::Retries=5 -o Acquire::http::Timeout=30 -o Acquire::https::Timeout=30 install -y --no-install-recommends \
        fontconfig \
        fonts-noto-cjk \
        xz-utils && \
    rm -rf /var/lib/apt/lists/* && \
    chmod +x /usr/local/bin/playwright-installer && \
    chmod +x /usr/local/bin/fingerprint-browser-installer && \
    /usr/local/bin/playwright-installer && \
    /usr/local/bin/fingerprint-browser-installer && \
    fc-cache -f && \
    mkdir -p /app/logs /app/tmp /app/chrome /opt/fingerprint-chrome
