# syntax=docker/dockerfile:1.7

ARG RUNTIME_BASE_IMAGE=xuwei190/crawler-env:latest

FROM golang:1.25-alpine AS builder

RUN apk add --no-cache git make

WORKDIR /app

ARG SERVICE_CMD=./cmd/shein-listing/main.go

COPY go.mod go.sum ./
RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
    go mod download

COPY . .

RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
    CGO_ENABLED=0 GOOS=linux go build \
        -ldflags="-s -w" \
        -o listing-service \
        "${SERVICE_CMD}"

FROM ${RUNTIME_BASE_IMAGE}

ENV TZ=Asia/Shanghai
ENV FINGERPRINT_CHROME_VERSION=144
ENV FINGERPRINT_CHROME_DIR=/opt/fingerprint-chrome

WORKDIR /app

RUN mkdir -p /app/logs /app/tmp /app/chrome /opt/fingerprint-chrome

COPY --from=builder /app/listing-service /app/listing-service
COPY --from=builder /app/config ./config
COPY --from=builder /app/prompts ./prompts

RUN chmod +x /app/listing-service

EXPOSE 8081 8082

CMD ["/app/listing-service", "-config", "config/config-prod.yaml", "-log-level", "info"]
