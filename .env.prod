# Environment variable configuration example
# Copy this file to .env and fill in your real values

# ==================== Application ====================
TASK_PROCESSOR_ENV=prod
TASK_PROCESSOR_LOG_LEVEL=info

# ==================== Management API ====================
TASK_PROCESSOR_MANAGEMENT_BASE_URL=http://api.shuomiai.com
TASK_PROCESSOR_MANAGEMENT_CLIENT_ID=go-listing
TASK_PROCESSOR_MANAGEMENT_CLIENT_SECRET=go-listing-secret
TASK_PROCESSOR_MANAGEMENT_TOKEN_URL=http://api.shuomiai.com/admin-api/system/oauth2/token
TASK_PROCESSOR_MANAGEMENT_TENANT_ID=1
# 逗号分隔的店铺ID列表，示例中是三个店铺ID：837、838、839。根据实际情况替换为你的店铺ID列表。
TASK_PROCESSOR_MANAGEMENT_STORE_IDS=869

# ==================== RabbitMQ ====================
TASK_PROCESSOR_RABBITMQ_ENABLED=true
# RabbitMQ AMQP 连接地址，可包含用户/密码/host/port/vhost。
TASK_PROCESSOR_RABBITMQ_URL=amqp://admin:RabbitMQ%402026%23Prod@101.33.34.102:30567/

# RabbitMQ consumer 节点并发度（每个节点最多可同时处理任务数量）。
TASK_PROCESSOR_RABBITMQ_NODE_MAX_CONCURRENCY=1

# RabbitMQ consumer 节点健康检查和指标端口（可选，用于监控）。
TASK_PROCESSOR_RABBITMQ_NODE_HEALTH_CHECK_PORT=8081
TASK_PROCESSOR_RABBITMQ_NODE_METRICS_PORT=8082


# ==================== OpenAI ====================
TASK_PROCESSOR_OPENAI_API_KEY=sk-ctFAGZDOnkWNKfCcAoJ2LEm19xYhXPS92HbXZxTEITVemv8o
TASK_PROCESSOR_OPENAI_MODEL=gemini-2.5-flash-lite
TASK_PROCESSOR_OPENAI_BASE_URL=https://api.gptbest.vip/v1

# ==================== Amazon SP-API ====================
TASK_PROCESSOR_AMAZON_SPAPI_CLIENT_ID=your-client-id
TASK_PROCESSOR_AMAZON_SPAPI_CLIENT_SECRET=your-client-secret
TASK_PROCESSOR_AMAZON_SPAPI_REFRESH_TOKEN=your-refresh-token
TASK_PROCESSOR_AMAZON_SPAPI_REGION=us-east-1
TASK_PROCESSOR_AMAZON_SPAPI_DEFAULT_MARKETPLACE=ATVPDKIKX0DER
TASK_PROCESSOR_AMAZON_SPAPI_DEFAULT_FULFILLMENT_TYPE=MFN
TASK_PROCESSOR_AMAZON_SPAPI_DEFAULT_CONDITION=New

# ==================== Browser ====================
TASK_PROCESSOR_BROWSER_HEADLESS=true
TASK_PROCESSOR_BROWSER_POOL_SIZE=3
TASK_PROCESSOR_BROWSER_PATH=./chrome/chrome.exe

# ==================== Worker ====================
TASK_PROCESSOR_WORKER_CONCURRENCY=1
TASK_PROCESSOR_WORKER_BUFFER_SIZE=5
TASK_PROCESSOR_WORKER_TASK_INTERVAL=30

# ==================== Platforms ====================
TASK_PROCESSOR_PLATFORM_TEMU_ENABLED=true
TASK_PROCESSOR_PLATFORM_SHEIN_ENABLED=true

# ==================== Database (optional) ====================
TASK_PROCESSOR_DATABASE_HOST=23.144.68.51
TASK_PROCESSOR_DATABASE_PORT=30460
TASK_PROCESSOR_DATABASE_NAME=ruoyi-vue-pro
TASK_PROCESSOR_DATABASE_USER=postgres
TASK_PROCESSOR_DATABASE_PASSWORD=postgresql2026Zone$
# Deprecated aliases: DB_HOST, DB_PORT, DB_NAME, DB_USER, DB_PASSWORD

# ==================== Redis (optional, productenrich queue / cache) ====================
TASK_PROCESSOR_REDIS_HOST=23.144.68.51
TASK_PROCESSOR_REDIS_PORT=30379
TASK_PROCESSOR_REDIS_PASSWORD=8idSRwLEauYs0taf_MYEDaV%
TASK_PROCESSOR_REDIS_DB=8
# Deprecated aliases (will log warnings): REDIS_HOST, REDIS_PORT, REDIS_PASSWORD, REDIS_DB
