# 指定在索引时要忽略的文件或文件夹。与.gitignore匹配规则一致，支持 my-security/ 和 *.log 等通配符模式。

# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Go workspace file
go.work

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Log files
*.log

# Environment variables
.env
.env.local
.env.*.local

# Build output
/bin/
/build/
/dist/

# Chrome browser files (if not needed)
chrome/

# Config files with sensitive data
config/*local*.yaml

/cache
test_data
logs
.venv
.kiro
.trae
.new
.update-marker
.understand-anything
.gocache/
.local/
tmp/*
!tmp/go.mod
!tmp/README.md
.tmp/
.playwright-cli/
.tools/
.codegraph/
web/listingkit-ui/.data/
node_modules/
test-results/
web/listingkit-ui/test-results/
web/listingkit-ui/.next/
web/listingkit-ui/node_modules/
web/listingkit-ui/tsconfig.tsbuildinfo

# Local SDS/SHEIN integration state and credentials
data/sds/
internal/sdslogin/data/sds/*.json

# Temporary and cache directories
.migrations/
.hack/

# Docker related
.dockerignore
.codex-backups/
.qoder/
.agents/

# Documentation and examples
docs/
examples/
tests/

# Tool specific
tools/json-simplifier/result

# Service specific logs and tmp
cmd/product-listing-api/logs
cmd/product-listing-api/tmp
cmd/productenrich-api/logs
cmd/productenrich-api/tmp

# Web frontend specific
web/listingkit-ui/coverage
web/listingkit-ui/.turbo
tools/**/node_modules