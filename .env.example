# Environment variable configuration example
# Copy this file to .env and fill in your real values

# ==================== Application ====================
TASK_PROCESSOR_ENV=dev
TASK_PROCESSOR_LOG_LEVEL=info

# ==================== Management API ====================
TASK_PROCESSOR_MANAGEMENT_BASE_URL=http://localhost:8080
TASK_PROCESSOR_MANAGEMENT_CLIENT_ID=go-listing
TASK_PROCESSOR_MANAGEMENT_CLIENT_SECRET=replace-me
TASK_PROCESSOR_MANAGEMENT_TOKEN_URL=http://localhost:8080/admin-api/system/oauth2/token
TASK_PROCESSOR_MANAGEMENT_TENANT_ID=1

# ==================== RabbitMQ ====================
TASK_PROCESSOR_RABBITMQ_URL=amqp://guest:guest@localhost:5672/
TASK_PROCESSOR_RABBITMQ_NODE_ROLE=hybrid
TASK_PROCESSOR_RABBITMQ_NODE_MAX_CONCURRENCY=5
TASK_PROCESSOR_RABBITMQ_NODE_HEALTH_CHECK_PORT=8081
TASK_PROCESSOR_RABBITMQ_NODE_METRICS_PORT=8082

# Deprecated aliases still supported during migration:
# HEALTH_CHECK_PORT=8081
# METRICS_PORT=8082

# ==================== OpenAI ====================
TASK_PROCESSOR_OPENAI_API_KEY=replace-me
TASK_PROCESSOR_OPENAI_MODEL=gemini-2.0-flash
TASK_PROCESSOR_OPENAI_BASE_URL=https://ai.linkcloudai.com/v1

# ==================== Amazon SP-API ====================
TASK_PROCESSOR_AMAZON_SPAPI_CLIENT_ID=your-client-id
TASK_PROCESSOR_AMAZON_SPAPI_CLIENT_SECRET=your-client-secret
TASK_PROCESSOR_AMAZON_SPAPI_REFRESH_TOKEN=your-refresh-token
TASK_PROCESSOR_AMAZON_SPAPI_REGION=us-east-1
TASK_PROCESSOR_AMAZON_SPAPI_DEFAULT_MARKETPLACE=ATVPDKIKX0DER
TASK_PROCESSOR_AMAZON_SPAPI_DEFAULT_FULFILLMENT_TYPE=MFN
TASK_PROCESSOR_AMAZON_SPAPI_DEFAULT_CONDITION=New
TASK_PROCESSOR_AMAZON_REMOTE_API_ENABLED=false
TASK_PROCESSOR_AMAZON_REMOTE_API_BASE_URL=http://localhost:8080
TASK_PROCESSOR_AMAZON_REMOTE_API_TIMEOUT=300

# Deprecated aliases still supported during migration:
# AMAZON_SPAPI_CLIENT_ID=your-client-id
# AMAZON_SPAPI_CLIENT_SECRET=your-client-secret
# AMAZON_SPAPI_REFRESH_TOKEN=your-refresh-token
# AMAZON_SPAPI_REGION=us-east-1
# AMAZON_SPAPI_MARKETPLACE_ID=ATVPDKIKX0DER

# ==================== Browser ====================
TASK_PROCESSOR_BROWSER_HEADLESS=true
TASK_PROCESSOR_BROWSER_POOL_SIZE=3
TASK_PROCESSOR_BROWSER_PATH=./chrome/chrome.exe

# ==================== Worker ====================
TASK_PROCESSOR_WORKER_CONCURRENCY=5
TASK_PROCESSOR_WORKER_BUFFER_SIZE=100
TASK_PROCESSOR_WORKER_TASK_INTERVAL=30

# ==================== ListingKit Auth (ZITADEL) ====================
# The Next.js UI still reads these runtime env vars directly.
# The Go API now loads the same values through core config as
# listingkit.zitadel.* via env binding.
# Auth.js now owns the browser OIDC flow for ListingKit.
# AUTH_SECRET should be a stable random secret in every deployed environment.
# AUTH_SECRET=replace-with-random-secret
# ZITADEL_ISSUER_URL=https://your-instance.zitadel.cloud
# ZITADEL_CLIENT_ID=your-client-id
# ZITADEL_CLIENT_SECRET=your-client-secret
# ZITADEL redirect URI should allow Auth.js callback:
# http://localhost:3000/api/auth/callback/zitadel
# ZITADEL_POST_LOGOUT_REDIRECT_URI=http://localhost:3000
# LISTINGKIT_PUBLIC_BASE_URL=http://localhost:3000
# NEXT_PUBLIC_ZITADEL_CONSOLE_URL=https://auth.example.com/ui/console
# Optional frontend poll interval for the in-app "new version available"
# refresh banner, in milliseconds. Defaults to 60000 when omitted.
# NEXT_PUBLIC_LISTINGKIT_UPDATE_POLL_INTERVAL_MS=60000
# Include the role scopes printed by cmd/listingkit-zitadel-provision; the Go
# API uses those role claims for route-level authorization.
# ZITADEL_SCOPES=openid profile email urn:zitadel:iam:user:resourceowner urn:zitadel:iam:org:project:id:zitadel:aud urn:zitadel:iam:org:project:role:listingkit_viewer urn:zitadel:iam:org:project:role:listingkit_operator urn:zitadel:iam:org:project:role:listingkit_admin urn:zitadel:iam:org:project:role:platform_admin
# Set this to fail closed when the Go API starts without listingkit.zitadel
# credentials.
# TASK_PROCESSOR_LISTINGKIT_ZITADEL_AUTH_REQUIRED=1
# Optional ListingKit authorization allowlists. When any allowlist is set, or
# TASK_PROCESSOR_LISTINGKIT_ZITADEL_AUTHZ_REQUIRED=1, authenticated users must
# match at least one configured tenant ID, user ID, username, or role.
# LISTINGKIT_ZITADEL_ALLOWED_TENANT_IDS=373160030834237955
# LISTINGKIT_ZITADEL_ALLOWED_USER_IDS=373160103106314243
# LISTINGKIT_ZITADEL_ALLOWED_USERNAMES=1-admin
# LISTINGKIT_ZITADEL_ALLOWED_ROLES=listingkit_admin,platform_admin
# TASK_PROCESSOR_LISTINGKIT_ZITADEL_AUTHZ_REQUIRED=1
# Optional ZITADEL provisioning inputs for the operator-only
# cmd/listingkit-zitadel-provision tool. Do not pass the management token to
# normal UI/API runtimes.
# ZITADEL_MANAGEMENT_TOKEN=replace-with-management-api-token
# ZITADEL_ORG_ID=373160030834237955
# LISTINGKIT_ZITADEL_PROJECT_ID=373160000000000000
# LISTINGKIT_ZITADEL_PROJECT_NAME=ListingKit
# Recommended after running provisioning:
# LISTINGKIT_ZITADEL_ALLOWED_ROLES=listingkit_admin,listingkit_operator,listingkit_viewer,platform_admin
# Optional service account / machine-to-machine credentials for local API
# debugging and automation. Create a ZITADEL Service Account, grant it a
# ListingKit role, generate a client secret, and include the project audience
# scope so the Go API can introspect the issued access token.
# LISTINGKIT_MACHINE_ZITADEL_ISSUER_URL=https://your-instance.zitadel.cloud
# LISTINGKIT_MACHINE_CLIENT_ID=your-service-account-client-id
# LISTINGKIT_MACHINE_CLIENT_SECRET=your-service-account-client-secret
# LISTINGKIT_MACHINE_SCOPES=openid profile urn:zitadel:iam:user:resourceowner urn:zitadel:iam:org:project:id:<listingkit-project-id>:aud
# Optional owner scope for ListingKit task/studio data. When enabled, ListingKit
# task and studio queries are filtered by the authenticated ZITADEL user ID in
# addition to tenant ID. Existing historical rows without user_id will no
# longer be visible until they are backfilled.
# TASK_PROCESSOR_LISTINGKIT_ZITADEL_OWNER_SCOPE_REQUIRED=1

# Equivalent Go API YAML shape:
# listingkit:
#   zitadel:
#     issuerURL: "https://your-instance.zitadel.cloud"
#     clientID: "your-client-id"
#     clientSecret: "your-client-secret"
#     authRequired: true
#     authorizationRequired: true
#     allowedRoles: ["listingkit_admin", "platform_admin"]

# ==================== ListingKit Studio Async Jobs ====================
# Optional file-backed store for Go Studio async job snapshots. Set this to a
# persistent volume path when API processes may restart. If unset, jobs stay
# in memory and are lost on process restart.
# LISTINGKIT_STUDIO_ASYNC_JOB_STORE_PATH=./data/listingkit-studio-async-jobs.json

# ==================== Platforms ====================
TASK_PROCESSOR_PLATFORM_TEMU_ENABLED=true
TASK_PROCESSOR_PLATFORM_SHEIN_ENABLED=true
TASK_PROCESSOR_PLATFORM_1688_ENABLED=true

# ==================== Database (optional) ====================
# TASK_PROCESSOR_DATABASE_HOST=localhost
# TASK_PROCESSOR_DATABASE_PORT=5432
# TASK_PROCESSOR_DATABASE_NAME=task_processor
# TASK_PROCESSOR_DATABASE_USER=postgres
# TASK_PROCESSOR_DATABASE_PASSWORD=your-password
# Deprecated aliases: DB_HOST, DB_PORT, DB_NAME, DB_USER, DB_PASSWORD

# ==================== Redis (optional, productenrich queue / cache) ====================
# TASK_PROCESSOR_REDIS_HOST=localhost
# TASK_PROCESSOR_REDIS_PORT=6379
# TASK_PROCESSOR_REDIS_PASSWORD=
# TASK_PROCESSOR_REDIS_DB=0
# TASK_PROCESSOR_SDS_AUTH_REDIS_HOST=localhost
# TASK_PROCESSOR_SDS_AUTH_REDIS_PORT=6379
# TASK_PROCESSOR_SDS_AUTH_REDIS_PASSWORD=
# TASK_PROCESSOR_SDS_AUTH_REDIS_DB=9
