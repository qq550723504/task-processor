# 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ==================== 应用配置 ====================
APP_ENV=development
LOG_LEVEL=info

# ==================== 管理系统 API ====================
MANAGEMENT_BASE_URL=http://localhost:8080
MANAGEMENT_CLIENT_ID=go-listing
MANAGEMENT_CLIENT_SECRET=go-listing-secret
MANAGEMENT_TOKEN_URL=http://localhost:8080/admin-api/system/oauth2/token

# ==================== RabbitMQ 配置 ====================
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_RECONNECT_INTERVAL=5s
RABBITMQ_MAX_RECONNECT_TRIES=10

# ==================== 监控端口 ====================
HEALTH_CHECK_PORT=8081
METRICS_PORT=8082

# ==================== OpenAI 配置 ====================
OPENAI_API_KEY=your-api-key-here
OPENAI_MODEL=gemini-2.0-flash
OPENAI_BASE_URL=https://ai.linkcloudai.com/v1

# ==================== Amazon SP-API 配置 ====================
AMAZON_SPAPI_CLIENT_ID=your-client-id
AMAZON_SPAPI_CLIENT_SECRET=your-client-secret
AMAZON_SPAPI_REFRESH_TOKEN=your-refresh-token
AMAZON_SPAPI_REGION=us-east-1
AMAZON_SPAPI_MARKETPLACE_ID=ATVPDKIKX0DER

# ==================== 浏览器配置 ====================
BROWSER_HEADLESS=true
BROWSER_POOL_SIZE=3
BROWSER_PATH=./chrome/chrome.exe

# ==================== Worker 配置 ====================
WORKER_CONCURRENCY=5
WORKER_BUFFER_SIZE=100
WORKER_TASK_INTERVAL=30

# ==================== 平台开关 ====================
PLATFORM_TEMU_ENABLED=true
PLATFORM_SHEIN_ENABLED=true
PLATFORM_AMAZON_ENABLED=true
PLATFORM_1688_ENABLED=true

# ==================== 数据库配置（如果需要）====================
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=task_processor
# DB_USER=postgres
# DB_PASSWORD=your-password

# ==================== Redis 配置（用于分布式锁）====================
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0
